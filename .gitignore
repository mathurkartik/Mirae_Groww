# Mutual Fund FAQ Assistant — .gitignore

# ── Secrets (NEVER commit) ────────────────────────────
.env
*.env.local

# ── Python ───────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
.Python
*.egg-info/
dist/
build/
.eggs/
*.egg

# ── Virtual environments ──────────────────────────────
venv/
.venv/
env/
.env/

# ── Data (large/generated files) ─────────────────────
data/raw/
data/chroma_db/
data/cleaned_docs.jsonl
data/chunks.jsonl
data/ingestion_manifest.json

# ── HuggingFace model cache ───────────────────────────
.cache/

# ── IDE ───────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo

# ── OS ───────────────────────────────────────────────
.DS_Store
Thumbs.db

# ── Node (frontend) ──────────────────────────────────
node_modules/
.next/
out/
