# .env.example — Mutual Fund FAQ Assistant
# Copy this file to .env and fill in your values.
# NEVER commit .env to Git.

# ──────────────────────────────────────────────────────
# Groq LLM  (required for Phase 6 — generator.py)
# Get your key at: https://console.groq.com/keys
# ──────────────────────────────────────────────────────
GROQ_API_KEY=gsk_your_groq_api_key_here

# Groq model (optional — default: llama3-8b-8192)
# GROQ_MODEL=llama3-8b-8192

# ──────────────────────────────────────────────────────
# Ingestion pipeline (optional overrides)
# ──────────────────────────────────────────────────────
# CHROMA_PERSIST_PATH=data/chroma_db
# CHROMA_COLLECTION=mutual_fund_faq
# CHUNKS_JSONL=data/chunks.jsonl
# EMBEDDING_MODEL=BAAI/bge-small-en-v1.5
# PIPELINE_RUN_ID=local

# ──────────────────────────────────────────────────────
# Retrieval (optional overrides)
# ──────────────────────────────────────────────────────
# DENSE_TOP_K=10
# SPARSE_TOP_K=10
# RRF_TOP_N=5
# RERANK_TOP_N=3
# CONFIDENCE_THRESHOLD=0.30
# RERANKER_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2

# ──────────────────────────────────────────────────────
# Deployment (Render / Vercel)
# ──────────────────────────────────────────────────────
# NEXT_PUBLIC_API_URL=https://your-render-service.onrender.com
# RENDER_DEPLOY_HOOK=https://api.render.com/deploy/srv-...
